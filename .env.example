# ──────────────────────────────────────────────────────────────
# Local development — copy to .env and edit values
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection. The app is Postgres-only (local + production).
# For local dev, run Postgres via Docker (see DEPLOYMENT.md) or point at a
# cloud DB. Use the POOLED url here (port 6543 on Neon/Supabase).
DATABASE_URL="postgresql://postgres:local@localhost:5432/shift_scheduler?schema=public"
# DIRECT (non-pooled) url used by `prisma migrate`. If your provider has only
# one url, set this to the same value as DATABASE_URL.
DIRECT_URL="postgresql://postgres:local@localhost:5432/shift_scheduler?schema=public"

# REQUIRED. Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# Used by the share-form card so it can render a public link
# Leave empty in dev; the card auto-detects LAN IPs.
PUBLIC_URL=""

# Bootstrap script (scripts/bootstrap-admin.ts) — only needed for first deploy
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME=""
RESTAURANT_NAME=""

# Used only by the local seed (prisma/seed.ts), NOT in production
DEFAULT_MANAGER_EMAIL="manager@example.com"
DEFAULT_MANAGER_PASSWORD="changeme"

# Optional — Claude Haiku LLM fallback for ambiguous availability parsing
ANTHROPIC_API_KEY=""
